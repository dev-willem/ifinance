# ──────────────────────────────────────────
#  iFinance — variáveis de ambiente
#  Copie para .env e preencha com seus valores
# ──────────────────────────────────────────

# Banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ifinance_dev
DB_USERNAME=ifinance
DB_PASSWORD=troque-esta-senha

# OAuth2 Google
# Obtenha em: https://console.cloud.google.com → APIs → Credenciais
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# Servidor backend (docker/prod)
SERVER_PORT=8080

# Imagens Docker (CI/CD — opcional localmente)
BACKEND_IMAGE=ghcr.io/willembergfilho/ifinance-backend:latest
FRONTEND_IMAGE=ghcr.io/willembergfilho/ifinance-frontend:latest

# URL pública da API (usada no build do frontend)
# Deixe vazio para o perfil docker (browser acessa localhost:8080)
VITE_API_BASE_URL=http://localhost:8080
